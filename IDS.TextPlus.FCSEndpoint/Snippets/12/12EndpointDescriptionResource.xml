<ed:Resource pid="{{pid}}">
  <ed:Title xml:lang="en">{{title_eng}}</ed:Title>
  <ed:Title xml:lang="de" primary="true">{{title_deu}}</ed:Title>  
  <ed:Description xml:lang="en">{{description_eng}}</ed:Description>
  <ed:Description xml:lang="de" primary="true">{{description_deu}}</ed:Description>
  <ed:Institution xml:lang="en">{{institution_eng}}</ed:Institution>
  <ed:Institution xml:lang="de" primary="true">{{institution_deu}}</ed:Institution>
  <ed:LandingPageURI>{{landingpage}}</ed:LandingPageURI>
  <ed:Languages>
    {{languages}}
  </ed:Languages>
  <ed:AvailableDataViews ref="{{dataviews}}"/>
  <ed:AvailableLexFields ref="{{lexfields}}"/>
</ed:Resource>